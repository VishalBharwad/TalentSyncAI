@{
    ViewData["Title"] = "Join TalentSyncAI";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-10">

            <div class="text-center mb-5">

                <img src="~/images/logo/logo.png"
                     alt="TalentSyncAI"
                     height="80"
                     class="mb-3" />

                <h1 class="fw-bold">

                    Join TalentSyncAI

                </h1>

                <p class="text-muted">

                    Choose how you want to use TalentSyncAI.

                </p>

            </div>

            <div class="row">

                <!-- Recruiter -->

                <div class="col-md-6 mb-4">

                    <div class="card shadow border-0 h-100">

                        <div class="card-body text-center p-5">

                            <i class="fas fa-building fa-4x text-primary mb-4"></i>

                            <h3>Recruiter</h3>

                            <p class="text-muted">

                                Register your company, post jobs, and hire the best candidates.

                            </p>

                            <a asp-controller="Register"
                               asp-action="Recruiter"
                               class="btn btn-primary btn-lg w-100">

                                Register as Recruiter

                            </a>

                        </div>

                    </div>

                </div>

                <!-- Candidate -->

                <div class="col-md-6 mb-4">

                    <div class="card shadow border-0 h-100">

                        <div class="card-body text-center p-5">

                            <i class="fas fa-user-graduate fa-4x text-success mb-4"></i>

                            <h3>Candidate</h3>

                            <p class="text-muted">

                                Create your profile, upload your resume and apply for jobs.

                            </p>

                            <a asp-controller="Register"
                               asp-action="Candidate"
                               class="btn btn-success btn-lg w-100">

                                Register as Candidate

                            </a>

                        </div>

                    </div>

                </div>

            </div>

            <div class="text-center mt-4">

                <p>

                    Already have an account?

                    <a asp-controller="Account"
                       asp-action="Login">

                        Login Here

                    </a>

                </p>

            </div>

        </div>

    </div>

</div>